# ROS 2 Jazzy environment
source /opt/ros/jazzy/setup.bash

# Auto-source current workspace if install exists
if [ -f "$PWD/install/setup.bash" ]; then
  source "$PWD/install/setup.bash"
fi

# Common ROS/Gazebo hints
export ROS_DISTRO=jazzy
export RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Gazebo NVIDIA offload helper
alias gzsim-nvidia='QT_QPA_PLATFORM=xcb __NV_PRIME_RENDER_OFFLOAD=1 __GLX_VENDOR_LIBRARY_NAME=nvidia __VK_LAYER_NV_optimus=NVIDIA_only gz sim'

echo "[ros2 env] ROS 2 Jazzy loaded for: $PWD"
